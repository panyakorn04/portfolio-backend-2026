# PostgreSQL connection (pgx URL form).
# Supabase: use the Transaction pooler (port 6543) for serverless, or the
# direct/session connection (port 5432) for long-lived servers.
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio?sslmode=disable

# Public site URL. Used to decide whether the session cookie is Secure.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Outbound webhook for contact submissions (optional).
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=

# Static bearer tokens (optional).
ADMIN_API_TOKEN=
INTERNAL_API_TOKEN=

# AI provider config (optional).
AI_PROVIDER=stub
AI_API_KEY=
