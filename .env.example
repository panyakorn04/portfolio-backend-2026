# Supabase REST configuration.
# Backend writes/admin/session/contact actions should use the service role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Redis cache for public article GET responses.
# Leave REDIS_URL empty to disable cache.
REDIS_URL=redis://localhost:6379/0
ARTICLE_CACHE_TTL_SECONDS=300

# Public site URL. Used to decide whether the session cookie is Secure.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Outbound webhook for contact submissions (optional).
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=

# Static bearer tokens (optional).
ADMIN_API_TOKEN=
INTERNAL_API_TOKEN=
# Required for Studio encrypted credentials. Generate with: openssl rand -base64 32
STUDIO_CREDENTIAL_ENCRYPTION_KEY=
# Independent HMAC key for individually revocable Studio webhook capabilities.
STUDIO_WEBHOOK_SIGNING_KEY=

# AI provider config (optional).
AI_PROVIDER=stub
AI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=panyakorn-local:latest
# Comma-separated whitelist for public chat model selection. Defaults to OLLAMA_MODEL when empty.
OLLAMA_ALLOWED_MODELS=panyakorn-local:latest,qwen2.5-coder:7b
AI_SKILLS_DIR=/opt/ai/skills

# Public portfolio assistant anonymous backend sessions.
# Generate a long random value for production, e.g. `openssl rand -base64 48`.
PORTFOLIO_CHAT_VISITOR_SECRET=
PORTFOLIO_CHAT_SESSION_TTL_HOURS=2160
PORTFOLIO_CHAT_MAX_STORED_MESSAGES=100
